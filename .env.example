# ── App ────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# !! 반드시 변경 !!
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_PASSWORD=your-pg-password

# ── Snowflake ───────────────────────────────────────────────────
# account 형식: orgname-account_name  (예: myorg-myaccount)
SNOWFLAKE_ACCOUNT=your-account-identifier
SNOWFLAKE_USER=your-snowflake-user
SNOWFLAKE_PASSWORD=your-snowflake-password

# RSA 키페어 인증 (권장) — SNOWFLAKE_PASSWORD 대신 사용
# SNOWFLAKE_PRIVATE_KEY_PATH=/app/keys/rsa_key.p8

SNOWFLAKE_WAREHOUSE=FACT_WH_S
SNOWFLAKE_DATABASE=FACT_DB
SNOWFLAKE_ROLE=FACT_APP_ROLE

# ── AWS S3 (보고서 파일 저장) ────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── 알림 ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
